#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

NAME="lanspeedd"
PROG="/usr/sbin/lanspeedd"
TC="/sbin/tc"
LANSPEED_TC_OWNER="lanspeed"
LANSPEED_TC_PREF="49152"
LANSPEED_TC_HANDLE="0x1eed"
LANSPEED_TC_EARLY_PREF="1"
LANSPEED_TC_EARLY_HANDLE="0x1eee"
LANSPEED_TC_OBJECT="/usr/lib/bpf/lanspeed_tc.o"

config_ifaces() {
	config_get ifnames "$1" ifname
	for ifname in $ifnames; do
		printf '%s\n' "$ifname"
	done

	config_get includes "$1" interface_include
	for ifname in $includes; do
		printf '%s\n' "$ifname"
	done
}

lanspeed_tc_filter_owned() {
	section="$1"
	if printf '%s\n' "$section" | grep -q "pref $LANSPEED_TC_PREF"; then
		printf '%s\n' "$section" | grep -q "handle $LANSPEED_TC_HANDLE" || return 1
	elif printf '%s\n' "$section" | grep -q "pref $LANSPEED_TC_EARLY_PREF"; then
		printf '%s\n' "$section" | grep -q "handle $LANSPEED_TC_EARLY_HANDLE" || return 1
	else
		return 1
	fi
	printf '%s\n' "$section" | grep -F -q "$LANSPEED_TC_OWNER" || return 1
	printf '%s\n' "$section" | grep -F -q "$LANSPEED_TC_OBJECT" || return 1
	return 0
}

cleanup_lanspeed_tc_filters_on_dev() {
	dev="$1"
	[ -n "$dev" ] || return 0
	[ -x "$TC" ] || return 0

	for direction in ingress egress; do
		sections=$($TC filter show dev "$dev" "$direction" 2>/dev/null | awk '
			/^filter / {
				if (entry != "") print entry;
				entry = $0;
				next;
			}
			{
				if (entry != "") entry = entry " " $0;
			}
			END {
				if (entry != "") print entry;
			}
		')

		printf '%s\n' "$sections" | while IFS= read -r filter; do
			if lanspeed_tc_filter_owned "$filter"; then
				if printf '%s\n' "$filter" | grep -q "pref $LANSPEED_TC_EARLY_PREF"; then
					logger -t "$NAME" "removing owned tc filter dev=$dev direction=$direction pref=$LANSPEED_TC_EARLY_PREF handle=$LANSPEED_TC_EARLY_HANDLE"
					$TC filter del dev "$dev" "$direction" pref "$LANSPEED_TC_EARLY_PREF" handle "$LANSPEED_TC_EARLY_HANDLE" 2>/dev/null || true
				else
					logger -t "$NAME" "removing owned tc filter dev=$dev direction=$direction pref=$LANSPEED_TC_PREF handle=$LANSPEED_TC_HANDLE"
					$TC filter del dev "$dev" "$direction" pref "$LANSPEED_TC_PREF" handle "$LANSPEED_TC_HANDLE" 2>/dev/null || true
				fi
			fi
		done
	done
}

cleanup_lanspeed_tc_filters() {
	config_load lanspeed
	config_foreach config_ifaces lanspeed | sort -u | while IFS= read -r ifname; do
		cleanup_lanspeed_tc_filters_on_dev "$ifname"
	done
}

start_service() {
	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	cleanup_lanspeed_tc_filters
}

reload_service() {
	cleanup_lanspeed_tc_filters
	restart
}

service_triggers() {
	procd_add_reload_trigger "lanspeed" "network"
	procd_add_interface_trigger "interface.*" "lan" /etc/init.d/lanspeedd reload
}
